# ==================================================
# Discord
# ==================================================

# Discord bot token
DISCORD_TOKEN=your_bot_token_here

# Discord application (client) ID
CLIENT_ID=your_application_client_id_here

# Development/testing guild ID
# Leave blank if deploying global commands only
GUILD_ID=your_test_server_id_here

# ==================================================
# Logging Channels
# ==================================================

# Moderation actions (warns, deletes, edits, etc.)
MOD_LOG_CHANNEL_ID=123456789012345678

# Deleted and edited message logs
MESSAGE_LOG_CHANNEL_ID=123456789012345678

# ==================================================
# Message Cache
# ==================================================

# Maximum number of messages to keep in memory
MAX_CACHED_MESSAGES=5000

# ==================================================
# Environment
# ==================================================

# production or development
NODE_ENV=production
